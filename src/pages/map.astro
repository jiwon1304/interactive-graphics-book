---
import ChapterLayout from '../layouts/ChapterLayout.astro';
import { chaptersBySection, getRelationEdges, chapterHref, READING_PATHS } from '../chapters';

// 라이브 챕터만, section별 컬럼으로 배치
const groups = chaptersBySection()
  .map((g) => ({ section: g.section, items: g.items.filter((c) => !c.draft) }))
  .filter((g) => g.items.length > 0);

const W = 168;
const H = 60;
const COLGAP = 56;
const ROWGAP = 18;
const PAD = 24;
const HEADER_Y = 64;
const COLPITCH = W + COLGAP;

interface MapNode {
  slug: string;
  lines: string[];
  x: number;
  y: number;
  col: number;
  cx: number;
  cy: number;
  leftX: number;
  rightX: number;
}

// 한글 기준 대략 maxChars로 줄바꿈(최대 maxLines줄, 넘치면 … 처리)
function wrap(text: string, maxChars: number, maxLines: number): string[] {
  const words = text.split(/\s+/);
  const lines: string[] = [];
  let cur = '';
  for (const w of words) {
    if (cur && (cur + ' ' + w).length > maxChars) {
      lines.push(cur);
      cur = w;
    } else {
      cur = cur ? cur + ' ' + w : w;
    }
  }
  if (cur) lines.push(cur);
  if (lines.length > maxLines) {
    lines.length = maxLines;
    const last = lines[maxLines - 1];
    lines[maxLines - 1] = last.slice(0, Math.max(0, maxChars - 1)) + '…';
  }
  return lines;
}

const nodes: MapNode[] = [];
const pos = new Map<string, MapNode>();
const headers: { lines: string[]; x: number }[] = [];
let maxRows = 0;

groups.forEach((g, col) => {
  maxRows = Math.max(maxRows, g.items.length);
  headers.push({ lines: wrap(g.section || '기타', 12, 2), x: PAD + col * COLPITCH });
  g.items.forEach((c, row) => {
    const x = PAD + col * COLPITCH;
    const y = HEADER_Y + row * (H + ROWGAP);
    const n: MapNode = {
      slug: c.slug,
      lines: wrap(c.title, 14, 3),
      x,
      y,
      col,
      cx: x + W / 2,
      cy: y + H / 2,
      leftX: x,
      rightX: x + W,
    };
    nodes.push(n);
    pos.set(c.slug, n);
  });
});

const width = PAD * 2 + groups.length * W + Math.max(0, groups.length - 1) * COLGAP;
const height = HEADER_Y + maxRows * (H + ROWGAP) - ROWGAP + PAD;

const edges = getRelationEdges()
  .map(({ a, b }) => ({ na: pos.get(a), nb: pos.get(b) }))
  .filter((e): e is { na: MapNode; nb: MapNode } => !!e.na && !!e.nb)
  .map(({ na, nb }) => {
    let path: string;
    if (na.col === nb.col) {
      const x = na.rightX;
      const cxp = x + 40;
      path = `M ${x} ${na.cy} C ${cxp} ${na.cy}, ${cxp} ${nb.cy}, ${x} ${nb.cy}`;
    } else {
      const [l, r] = na.col < nb.col ? [na, nb] : [nb, na];
      const mid = (l.rightX + r.leftX) / 2;
      path = `M ${l.rightX} ${l.cy} C ${mid} ${l.cy}, ${mid} ${r.cy}, ${r.leftX} ${r.cy}`;
    }
    return { a: na.slug, b: nb.slug, path };
  });

// 추천 읽기 경로: 라이브로 존재하는 노드만 추려 폴리라인(중심 연결)과 순번 배지 좌표를 만든다.
const paths = READING_PATHS.map((p) => {
  const pts = p.slugs
    .map((s) => pos.get(s))
    .filter((n): n is MapNode => !!n);
  return {
    id: p.id,
    title: p.title,
    description: p.description,
    slugs: pts.map((n) => n.slug),
    polyline: pts.map((n) => `${n.cx},${n.cy}`).join(' '),
    badges: pts.map((n, i) => ({ x: n.x, y: n.y, num: i + 1 })),
  };
}).filter((p) => p.badges.length >= 2);

// 클라이언트 스크립트로 넘길 최소 데이터(경로별 slug 목록·설명)
const pathData = Object.fromEntries(
  paths.map((p) => [p.id, { slugs: p.slugs, desc: p.description }]),
);
const defaultDesc =
  '노드에 마우스를 올리면(또는 포커스하면) 연결된 문서가 강조됩니다. 추천 경로 버튼을 누르면 읽는 순서를 따라 표시됩니다.';
---

<ChapterLayout
  title="지도 — 인터랙티브 컴퓨터 그래픽스"
  description="챕터들이 어떻게 이어지는지 한눈에 보는 지식 그래프"
>
  <h1>지도</h1>
  <p>
    챕터를 section별 열로 묶고, 개념적으로 이어지는 문서끼리 선으로 연결했습니다. 같은 열의 위→아래는
    대체로 읽는 순서입니다. 노드를 누르면 해당 챕터로 이동합니다.
    <em>(좁은 화면에서는 좌우로 스크롤하세요.)</em>
  </p>

  <div class="path-picker" role="group" aria-label="추천 읽기 경로">
    <button class="path-btn is-on" data-path="">자유 탐색</button>
    {paths.map((p) => (
      <button class="path-btn" data-path={p.id} title={p.description}>
        {p.title}
      </button>
    ))}
  </div>
  <p class="path-desc" id="path-desc">{defaultDesc}</p>

  <div class="map-scroll">
    <svg
      class="map-svg"
      viewBox={`0 0 ${width} ${height}`}
      width={width}
      height={height}
      role="img"
      aria-label="챕터 관계 그래프"
    >
      <g class="map-edges">
        {edges.map((e) => (
          <path class="map-edge" d={e.path} data-a={e.a} data-b={e.b} fill="none" />
        ))}
      </g>
      <g class="map-headers">
        {headers.map((h) =>
          h.lines.map((ln, i) => (
            <text class="map-header" x={h.x} y={20 + i * 16}>
              {ln}
            </text>
          ))
        )}
      </g>
      <g class="map-nodes">
        {nodes.map((n) => (
          <a href={chapterHref(n.slug)} class="map-node" data-slug={n.slug}>
            <rect x={n.x} y={n.y} width={W} height={H} rx="9" />
            <text
              class="map-node-label"
              x={n.cx}
              y={n.cy - ((n.lines.length - 1) * 13) / 2}
              text-anchor="middle"
            >
              {n.lines.map((ln, i) => (
                <tspan x={n.cx} dy={i === 0 ? 0 : 13}>
                  {ln}
                </tspan>
              ))}
            </text>
          </a>
        ))}
      </g>
      <g class="map-paths">
        {paths.map((p) => (
          <g class="map-path-group" data-path={p.id}>
            <polyline class="map-path-line" points={p.polyline} fill="none" />
            {p.badges.map((b) => (
              <g class="map-badge" transform={`translate(${b.x}, ${b.y})`}>
                <circle r="11" />
                <text text-anchor="middle" dy="0.34em">{b.num}</text>
              </g>
            ))}
          </g>
        ))}
      </g>
    </svg>
  </div>

  <script define:vars={{ pathData, defaultDesc }}>
    const svg = document.querySelector('.map-svg');
    if (svg) {
      const edges = Array.from(svg.querySelectorAll('.map-edge'));
      const nodes = Array.from(svg.querySelectorAll('.map-node'));
      const groups = Array.from(svg.querySelectorAll('.map-path-group'));
      const buttons = Array.from(document.querySelectorAll('.path-btn'));
      const descEl = document.getElementById('path-desc');

      // slug → 이웃 slug 집합 (호버 강조용)
      const neighbors = new Map();
      for (const e of edges) {
        const a = e.dataset.a;
        const b = e.dataset.b;
        if (!neighbors.has(a)) neighbors.set(a, new Set());
        if (!neighbors.has(b)) neighbors.set(b, new Set());
        neighbors.get(a).add(b);
        neighbors.get(b).add(a);
      }

      function activate(slug) {
        if (svg.classList.contains('path-mode')) return; // 경로 모드에선 호버 강조 끔
        const near = neighbors.get(slug) ?? new Set();
        svg.classList.add('has-active');
        for (const n of nodes) {
          const s = n.dataset.slug;
          n.classList.toggle('hot', s === slug || near.has(s));
        }
        for (const e of edges) {
          e.classList.toggle('hot', e.dataset.a === slug || e.dataset.b === slug);
        }
      }
      function clearHover() {
        svg.classList.remove('has-active');
        for (const n of nodes) n.classList.remove('hot');
        for (const e of edges) e.classList.remove('hot');
      }

      for (const n of nodes) {
        const slug = n.dataset.slug;
        n.addEventListener('mouseenter', () => activate(slug));
        n.addEventListener('mouseleave', clearHover);
        n.addEventListener('focus', () => activate(slug));
        n.addEventListener('blur', clearHover);
      }

      function setPath(id) {
        for (const b of buttons) b.classList.toggle('is-on', b.dataset.path === id);
        if (!id) {
          svg.classList.remove('path-mode');
          for (const g of groups) g.classList.remove('active');
          for (const n of nodes) n.classList.remove('onpath');
          if (descEl) descEl.textContent = defaultDesc;
          return;
        }
        clearHover();
        svg.classList.add('path-mode');
        for (const g of groups) g.classList.toggle('active', g.dataset.path === id);
        const info = pathData[id] ?? { slugs: [], desc: '' };
        const set = new Set(info.slugs);
        for (const n of nodes) n.classList.toggle('onpath', set.has(n.dataset.slug));
        if (descEl) descEl.textContent = info.desc;
      }

      for (const b of buttons) {
        b.addEventListener('click', () => setPath(b.dataset.path || ''));
      }
    }
  </script>

  <style>
    .path-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
      margin: 1.25rem 0 0.5rem;
    }
    .path-btn {
      font: inherit;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--muted);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 999px;
      padding: 0.3rem 0.8rem;
      cursor: pointer;
      transition: color 0.12s, border-color 0.12s, background 0.12s;
    }
    .path-btn:hover {
      color: var(--text);
      border-color: var(--accent);
    }
    .path-btn.is-on {
      color: var(--bg);
      background: var(--accent);
      border-color: var(--accent);
    }
    .path-desc {
      color: var(--muted);
      font-size: 0.9rem;
      margin: 0 0 0.25rem;
      min-height: 1.4em;
    }
    .map-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      margin: 1.5rem 0 1rem;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--surface);
      padding: 0.5rem;
    }
    .map-svg {
      display: block;
      height: auto;
    }
    .map-header {
      fill: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }
    .map-edge {
      stroke: var(--border);
      stroke-width: 1.6;
      transition: stroke 0.12s, stroke-width 0.12s, opacity 0.12s;
    }
    .map-node rect {
      fill: var(--bg);
      stroke: var(--border);
      stroke-width: 1.4;
      transition: stroke 0.12s, fill 0.12s;
    }
    .map-node-label {
      fill: var(--text);
      font-size: 11px;
      font-weight: 600;
      dominant-baseline: middle;
    }
    .map-node:hover rect,
    .map-node:focus rect {
      stroke: var(--accent);
    }
    .map-node:hover,
    .map-node:focus {
      text-decoration: none;
    }
    /* 한 노드 활성 시: 관련 없는 노드/엣지는 흐리게 */
    .map-svg.has-active .map-edge {
      opacity: 0.15;
    }
    .map-svg.has-active .map-edge.hot {
      opacity: 1;
      stroke: var(--accent);
      stroke-width: 2.4;
    }
    .map-svg.has-active .map-node:not(.hot) rect {
      opacity: 0.32;
    }
    .map-svg.has-active .map-node:not(.hot) .map-node-label {
      opacity: 0.32;
    }
    .map-svg.has-active .map-node.hot rect {
      stroke: var(--accent);
    }

    /* ── 추천 읽기 경로 오버레이 ── */
    .map-path-group {
      display: none;
    }
    .map-svg.path-mode .map-path-group.active {
      display: block;
    }
    .map-path-line {
      stroke: var(--accent);
      stroke-width: 2.6;
      stroke-linejoin: round;
      stroke-linecap: round;
      opacity: 0.85;
    }
    .map-badge circle {
      fill: var(--accent);
    }
    .map-badge text {
      fill: var(--bg);
      font-size: 11px;
      font-weight: 700;
    }
    /* 경로 모드: 경로 밖 노드/엣지는 흐리게, 경로 노드는 강조 */
    .map-svg.path-mode .map-edge {
      opacity: 0.08;
    }
    .map-svg.path-mode .map-node:not(.onpath) rect,
    .map-svg.path-mode .map-node:not(.onpath) .map-node-label {
      opacity: 0.28;
    }
    .map-svg.path-mode .map-node.onpath rect {
      stroke: var(--accent);
      stroke-width: 1.8;
    }
  </style>
</ChapterLayout>
