---
import ChapterLayout from '../layouts/ChapterLayout.astro';
import { chapters, chapterHref, homeHref } from '../chapters';

// 홈 목차에는 실제(비-draft) 챕터만 노출
const live = chapters.filter((c) => !c.draft);
---

<ChapterLayout
  title="인터랙티브 컴퓨터 그래픽스"
  description="그래픽스 기법을 글·수식·실시간 3D 데모로 직접 만져보며 이해하는 책"
>
  <h1>인터랙티브 컴퓨터 그래픽스</h1>
  <p>
    다양한 컴퓨터 그래픽스 기법을 글과 수식, 그리고 직접 조작할 수 있는 실시간 3D
    데모로 함께 이해하는 책입니다. 데스크톱과 모바일 모두에서 동작합니다.
  </p>
  <p>
    챕터들이 어떻게 이어지는지 한눈에 보려면 <a href={`${homeHref()}map`}>🗺️ 지도</a>를 펼쳐 보세요.
  </p>

  <h2>목차</h2>
  <ul class="toc">
    {
      live.map((c) => (
        <li>
          <a href={chapterHref(c.slug)}>{c.title}</a>
          {c.description && <span class="desc">{c.description}</span>}
        </li>
      ))
    }
  </ul>
</ChapterLayout>
